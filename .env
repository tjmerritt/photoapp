# PhotoApp — environment configuration
# Copy to .env and source it, or set these in your shell / docker-compose.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: full DSN
DATABASE_URL=postgres://photoapp:merritt.photos@localhost:5432/photoapp?sslmode=disable

# Option B: individual parts (used only when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=photoapp
# DB_PASSWORD=photoapp
# DB_NAME=photoapp

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_URL_BASE=/uploads

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ── Auth ──────────────────────────────────────────────────────────────────────
# Temporary: pass X-User-ID: <uuid> header to authenticate requests.
# Replace with JWT / session middleware when login is implemented.
AUTH_HEADER=X-User-ID
